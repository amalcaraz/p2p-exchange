{
  "name": "p2p-exchange",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "P2P distributed exchange with Lamport total-order broadcast over Grenache",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:grapes": "node node_modules/grenache-grape/bin/grape.js --dp 20001 --aph 30001 --bn '127.0.0.1:20002' --dpa 10000 & node node_modules/grenache-grape/bin/grape.js --dp 20002 --aph 40001 --bn '127.0.0.1:20001' --dpa 10000",
    "dev:node": "node --env-file=.env src/services/exchange/index.js",
    "dev:cluster": "node scripts/spawn-cluster.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test 'src/**/__tests__/*.test.js'",
    "test:integration": "node --test --test-force-exit 'src/**/__tests__/integration/*.test.js'",
    "test-exchange": "node --env-file=.env scripts/exchange-test-client.js",
    "cli": "node --env-file=.env scripts/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "grenache-grape": "^1.0.0",
    "grenache-nodejs-http": "^1.0.0",
    "grenache-nodejs-link": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
